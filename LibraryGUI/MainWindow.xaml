<Window x:Class="LibraryGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library"
        Height="450"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Grid>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="250">

            <TextBlock Text="Library"
                       FontSize="42"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Button x:Name="BtnRead"
                    Content="Read"
                    Height="45"
                    FontSize="16"
                    Margin="0,5"/>

            <Button x:Name="BtnCreate"
                    Content="Create"
                    Height="45"
                    FontSize="16"
                    Margin="0,5"/>

            <Button x:Name="BtnUpdate"
                    Content="Update"
                    Height="45"
                    FontSize="16"
                    Margin="0,5"/>

            <Button x:Name="BtnDelete"
                    Content="Delete"
                    Height="45"
                    FontSize="16"
                    Margin="0,5"/>

            <Separator Margin="0,20,0,10"/>

            <Button x:Name="BtnExit"
                    Content="Exit"
                    Height="40"
                    FontSize="15"
                    Background="#E53935"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>